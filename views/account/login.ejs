<h1>Login</h1>
<p>Don't have an account? <a href="/account/register">Register here</a></p>

<form method="post" action="/account/login">

    <div>
        <label for="email">Email:</label><br>
        <input type="email" id="email" name="account_email" required>
    </div>

    <div>
        <label for="password">Password:</label><br>
        <span>
            Must be at least 12 characters, include uppercase, lowercase, number, and special character
        </span><br>
        <input type="password" id="password" name="account_password" required
            pattern="^(?=.*\d)(?=.*[a-z])(?=.*[A-Z])(?=.*[^a-zA-Z0-9])(?!.*\s).{12,}$">
    </div>

    <br>
    <button type="submit">Login</button>

</form>