<h1>Register</h1>

<% if (errors) { %>
<ul class="notice">
    <% errors.array().forEach(error => { %>
    <li><%= error.msg %></li>
    <% }) %>
</ul>
<% } %>
<p>Already have an account? <a href="/account/login">Login here</a></p>

<form method="post" action="/account/register">

    <label>First Name:</label>
    <input type="text" name="account_firstname" required>

    <label>Last Name:</label>
    <input type="text" name="account_lastname" required>

    <label>Email:</label>
    <input type="email" name="account_email" required>

    <label>Password:</label>
    <span>
        Must be at least 12 characters, include uppercase, lowercase, number, and special character
    </span>
    <input type="password" name="account_password" required
        pattern="^(?=.*\d)(?=.*[a-z])(?=.*[A-Z])(?=.*[^a-zA-Z0-9])(?!.*\s).{12,}$">

    <button type="submit">Register</button>

</form>