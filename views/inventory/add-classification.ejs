<%- include('../partials/header') %>

<main class="add-classification">
    <h1>Add New Classification</h1>

    <div class="flash-message">
        <%- messages() %>
    </div>

    <form action="/inv/add-classification" method="post" class="account-form">
        <div class="form-group">
            <label for="classification_name">Classification Name</label>
            <small id="classificationHint" class="form-hint">
                No spaces or special characters allowed
            </small>
            <input type="text" name="classification_name" id="classification_name" required pattern="^[A-Za-z0-9]+$"
                aria-describedby="classificationHint">

            <% if (errors && errors.classification_name) { %>
            <span class="error"><%= errors.classification_name.msg %></span>
            <% } %>
        </div>

        <button type="submit" class="btn btn-primary">
            Add Classification
        </button>
    </form>
</main>

<%- include('../partials/footer') %>